{
  "name": "kjusys",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "start": "concurrently \"node prod-server/shell.js\"",
    "build:shell": "ng build shell --configuration=${BUILD_CONFIG:-production} --no-progress",
    "postbuild:shell": "node -e \"const fs=require('fs');fs.writeFileSync('dist/shell/assets/version.json',JSON.stringify({buildTime:new Date().toISOString()}));console.log('✅ version.json created');\"",
    "prebuild": "node scripts/inject-build-version.js",
    "prebuild:shell": "node scripts/inject-build-version.js",
    "build": "node scripts/dynamic-build.js \"npm run build:shell\"",
    "clean:cache": "rm -rf .angular/cache",
    "run:all": "node node_modules/@angular-architects/module-federation/src/server/mf-dev-server.js",
    "build:lib:stage1-base": "node scripts/dynamic-build.js --cooldown=1000 --headroom=512 \"ng build @libs/shared-auth\" \"ng build @libs/multi-dropdown-lib\" \"ng build @libs/alert\" \"ng build @libs/tabs\" \"ng build @libs/sub-tabs\" \"ng build @libs/shared-ui\" \"ng build @libs/dropdown-lib\" \"ng build @libs/table\" \"ng build @libs/shared-toast\" \"ng build @libs/pill-tabs\"",
    "build:lib:stage2-core": "ng build @libs/http-common",
    "build:lib:stage3-features": "node scripts/dynamic-build.js --cooldown=1000 --headroom=512 \"ng build @libs/menu-header-lib\" \"ng build @libs/left-menu-lib\"",
    "build:lib": "npm run build:lib:stage1-base && npm run build:lib:stage2-core && npm run build:lib:stage3-features",
    "serve": "concurrently \"ng serve shell --host 0.0.0.0 --disable-host-check\"",
    "create:module": "node scripts/create-module.js",
    "create:project": "node scripts/create-project.js",
    "lint": "ng lint"
  },
  "private": true,
